# Oneiro Ops webapp environment variables
# Copy to .env for local development; set the same keys in Railway for production.

# ── Apps Script proxy ─────────────────────────────────────────
APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
APPS_SCRIPT_KEY=

# ── Runtime ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Access gate ───────────────────────────────────────────────
# Shared "door codes" that unlock the site (see server.js "Access gate").
# ACCESS_KEY_ADMIN unlocks the full app; ACCESS_KEY_CREW unlocks the crew
# view (Nav + Field Report + Sign-In only). Users arrive via a link:
#   https://your-host/?key=<code>
# Leave BOTH blank to DISABLE the gate (site open to anyone, as before).
# Set them in Railway to turn the gate on; change a value to instantly
# revoke every old link (e.g. a departed employee) with no redeploy.
ACCESS_KEY_ADMIN=
ACCESS_KEY_CREW=

# ── QuickBooks Online integration ─────────────────────────────
# All five QB_* vars must be set for invoice generation to work. If any
# are missing the webapp boots cleanly but the WO Tracker will show
# "QuickBooks disconnected — click to reconnect" and Generate buttons
# fail closed. See docs/quickbooks_integration.md for setup.
#
# Sandbox vs production: same QB_CLIENT_ID/SECRET work for both. Switch
# QB_BASE_URL + QB_REALM_ID (and edit webapp/server/qbItems.js with the
# matching item IDs) to cut over.

QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://your-host/api/qb/auth-callback
QB_REALM_ID=
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com
# Production: https://quickbooks.api.intuit.com

# AES-256 key used to encrypt the refresh token before persisting it
# to Apps Script Properties. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Sandbox and production should use DIFFERENT keys; rotating the key
# invalidates the stored token and forces a re-auth.
QB_TOKEN_ENCRYPTION_KEY=
